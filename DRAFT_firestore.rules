rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'photoURL', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 256 &&
             data.photoURL is string && data.photoURL.size() <= 500 &&
             data.createdAt == request.time;
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['userId', 'input', 'identity', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.input is string && data.input.size() <= 10000 &&
             data.createdAt == request.time &&
             data.identity is map;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])
      );
    }

    match /brands/{brandId} {
      allow list, get: if true; // Community showcase access
      allow create: if isSignedIn() && isValidBrand(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
